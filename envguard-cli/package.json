{
  "name": "envguard-cli",
  "version": "0.1.0",
  "description": "Sync .env schemas across your team without storing secrets",
  "type": "module",
  "bin": {
    "envguard": "./dist/envguard.js"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "test": "jest",
    "start": "node ./dist/envguard.js",
    "build": "tsup src/bin/envguard.ts --format esm --clean"
  },
  "keywords": [
    "dotenv",
    "env",
    "cli",
    "developer-tools",
    "environment"
  ],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.15.0",
    "chalk": "^5.6.2",
    "commander": "^11.1.0",
    "dotenv": "^16.6.1",
    "inquirer": "^9.3.8",
    "jest": "^30.3.0",
    "keytar": "^7.9.0",
    "ora": "^6.3.1"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.5.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  }
}
